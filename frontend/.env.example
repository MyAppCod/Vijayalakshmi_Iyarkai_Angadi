# ── Frontend Environment Variables ──
# Copy this file to .env and fill in your values

# Backend API base URL
# Development:
# REACT_APP_API_URL=http://localhost:5000/api

# Production (your Render backend URL):
# REACT_APP_API_URL=https://via-backend.onrender.com/api
REACT_APP_API_URL=https://vijayalakshmi-iyarkai-angadi.onrender.com

# Backend media/uploads base URL
# Development: leave blank (defaults to http://localhost:5000)
REACT_APP_MEDIA_URL=

# Production (your Render backend URL — same as above without /api):
# REACT_APP_MEDIA_URL=https://via-backend.onrender.com
REACT_APP_MEDIA_URL=https://vijayalakshmi-iyarkai-angadi.onrender.com
