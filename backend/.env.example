# ── Backend Environment Variables ──
# Copy this file to .env and fill in your values

# Server
PORT=5000

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/organic_shop?retryWrites=true&w=majority

# JWT — use a long random string (min 32 characters)
JWT_SECRET=replace_this_with_a_long_random_secret_string

# Frontend URL (for CORS) — your Vercel URL in production
CLIENT_URL=http://localhost:3000

# UPI payment ID
UPI_ID=yourupi@bank

# Cloudinary — required for production image uploads
# Get these from cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
